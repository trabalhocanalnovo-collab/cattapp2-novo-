                              fg=C["text_white"], insertbackground=C["blue_light"],
                              relief="flat", bd=0)
        self._eqtd.pack(fill="x", ipady=14, padx=1)
        self._eqtd.insert(0, "1")
        self._eqtd.bind("<FocusIn>",  lambda e: qb.config(bg=C["blue_light"]))
        self._eqtd.bind("<FocusOut>", lambda e: qb.config(bg=C["blue_mid"]))

        uf = tk.Frame(row_qu, bg=C["bg_card"])
        uf.pack(side="left", fill="x", expand=True)
        tk.Label(uf, text="Unidade", font=F["body_sm"],
                 bg=C["bg_card"], fg=C["text_muted"]).pack(anchor="w", pady=(0, 4))
        s = ttk.Style()
        s.configure("D.TCombobox", fieldbackground=C["bg_input"],
                    background=C["bg_input"], foreground=C["text_white"],
                    selectbackground=C["blue_mid"], arrowcolor=C["blue_light"])
        self._cuni = ttk.Combobox(uf, values=self.UNIDADES,
                                  font=F["body_lg"], state="readonly",
                                  style="D.TCombobox")
        self._cuni.set("doses")
        self._cuni.pack(fill="x", ipady=8)

        ds = datetime.datetime.now().strftime("%d/%m/%Y  às  %H:%M")
        tk.Label(ci, text=f"📅  Será registrado em:  {ds}",
                 font=F["body_sm"], bg=C["bg_card"],
                 fg=C["text_dim"]).pack(anchor="w", pady=(0, 20))

        bf = tk.Frame(ci, bg=C["bg_card"])
        bf.pack(fill="x")
        BotaoAnimado(bf, "💾   Salvar Registro", self._salvar,
                     variante="sucesso", fonte=F["btn_lg"],
                     pady_base=16).pack(side="left", padx=(0, 16))
        BotaoAnimado(bf, "←  Cancelar", self.ao_voltar,
                     variante="ghost", fonte=F["btn"],
                     pady_base=16).pack(side="left")

        sf_widget.bind_scroll_em(sf)

    def _sel_bebida(self, beb):
        for b, w in self._btn_beb_wid.items():
            w.config(bg=C["bg_input"], fg=C["text_muted"])
        self._bebida_sel.set(beb)
        if beb in self._btn_beb_wid:
            self._btn_beb_wid[beb].config(bg=C["blue_mid"], fg=C["blue_soft"])

    def _salvar(self):
        bebida = self._bebida_sel.get()
        unidade = self._cuni.get()
        qtds = self._eqtd.get().strip().replace(",", ".")
        if not qtds:
            self.toast.mostrar("Informe a quantidade.", "aviso"); return
        try:
            qtd = float(qtds)
            if qtd <= 0: raise ValueError
        except ValueError:
            self.toast.mostrar("Quantidade inválida.", "erro"); return
        if self.banco.registrar_consumo(self.usuario["id"], bebida, qtd, unidade):
            self.toast.mostrar(f"Salvo: {qtd} {unidade} de {bebida}!", "sucesso")
            self.ao_voltar()
        else:
            self.toast.mostrar("Erro ao salvar. Tente novamente.", "erro")


