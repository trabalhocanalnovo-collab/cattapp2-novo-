class TelaHistorico(TelaBase):
    def __init__(self, frame, banco, usuario, toast, ao_voltar):
        self.frame    = frame
        self.banco    = banco
        self.usuario  = usuario
        self.toast    = toast
        self.ao_voltar = ao_voltar
        self._build()

    def _build(self):
        self._limpar()
        regs = self.banco.historico(self.usuario["id"])

        cab = tk.Frame(self.frame, bg=C["bg_main"], pady=26, padx=32)
        cab.pack(fill="x")
        tk.Label(cab, text="Histórico de Consumo 📋",
                 font=F["h1"], bg=C["bg_main"],
                 fg=C["text_white"]).pack(anchor="w")
        tk.Label(cab, text=f"{len(regs)} registro(s) encontrado(s)",
                 font=F["body"], bg=C["bg_main"],
                 fg=C["text_muted"]).pack(anchor="w", pady=(4, 0))

        co, ci = criar_card(self.frame, pad_x=0, pad_y=0)
        co.pack(fill="both", expand=True, padx=24, pady=(0, 16))

        if not regs:
            tk.Label(ci, text="😊\n\nNenhum registro ainda.\n"
                     "Use 'Registrar Consumo' para começar!",
                     font=F["body_lg"], bg=C["bg_card"],
                     fg=C["text_muted"], justify="center").pack(
                         expand=True, pady=60)
            return

        st = ttk.Style()
        st.theme_use("default")
        st.configure("H2.Treeview", background=C["bg_card"],
                     foreground=C["text_white"], rowheight=42,
                     fieldbackground=C["bg_card"], font=F["body_lg"],
                     borderwidth=0)
        st.configure("H2.Treeview.Heading", background=C["bg_deep"],
                     foreground=C["blue_light"], font=F["h3"], relief="flat")
        st.map("H2.Treeview",
               background=[("selected", C["blue_mid"])],
               foreground=[("selected", C["blue_soft"])])

        cols = ("#", "Bebida", "Quantidade", "Unidade", "Data / Hora")
        tree = ttk.Treeview(ci, columns=cols, show="headings",
                            style="H2.Treeview")
        for col, larg in zip(cols, [50, 200, 120, 110, 200]):
            tree.heading(col, text=col)
            tree.column(col, width=larg, anchor="center", minwidth=40)

        sy = ttk.Scrollbar(ci, orient="vertical", command=tree.yview)
        sx = ttk.Scrollbar(ci, orient="horizontal", command=tree.xview)
        tree.configure(yscrollcommand=sy.set, xscrollcommand=sx.set)

        # Scroll de mouse na Treeview também
        def _scroll_tree(event):
            if event.num == 4:   tree.yview_scroll(-1, "units")
            elif event.num == 5: tree.yview_scroll(1, "units")
            else:
                tree.yview_scroll(-1 if event.delta > 0 else 1, "units")
        tree.bind("<MouseWheel>", _scroll_tree)
        tree.bind("<Button-4>",   _scroll_tree)
        tree.bind("<Button-5>",   _scroll_tree)

        sy.pack(side="right", fill="y")
        sx.pack(side="bottom", fill="x")
        tree.pack(fill="both", expand=True)

        for i, (beb, qtd, uni, data) in enumerate(regs, 1):
            try:
                dt = datetime.datetime.strptime(data, "%Y-%m-%d %H:%M")
                df = dt.strftime("%d/%m/%Y   %H:%M")
            except ValueError:
                df = data
            tag = "par" if i % 2 == 0 else "impar"
            tree.insert("", "end", values=(i, beb, qtd, uni, df), tags=(tag,))
        tree.tag_configure("par",   background=C["bg_card"])
        tree.tag_configure("impar", background="#111D2E")


