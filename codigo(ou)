def criar_card(pai, titulo="", subtitulo="", icone="",
               cor_icone=None, pad_x=24, pad_y=20, cor_borda=None):
    cor_icone = cor_icone or C["blue_light"]
    cor_borda = cor_borda or C["blue_mid"]
    outer = tk.Frame(pai, bg=cor_borda, padx=1, pady=1)
    inner = tk.Frame(outer, bg=C["bg_card"], padx=pad_x, pady=pad_y)
    inner.pack(fill="both", expand=True)
    if icone or titulo:
        cab = tk.Frame(inner, bg=C["bg_card"])
        cab.pack(fill="x", anchor="w", pady=(0, 12))
        if icone:
            tk.Label(cab, text=icone, font=("Segoe UI", 20),
                     bg=C["bg_card"], fg=cor_icone).pack(
