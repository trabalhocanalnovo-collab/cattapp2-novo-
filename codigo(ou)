class BancoDados:
    """Gerencia todas as operações com SQLite."""

    def __init__(self):
        self.conexao = sqlite3.connect("sobertrack.db")
        self.cursor  = self.conexao.cursor()
        self._criar_tabelas()

    def _criar_tabelas(self):
        self.cursor.executescript("""
            CREATE TABLE IF NOT EXISTS usuarios (
                id    INTEGER PRIMARY KEY AUTOINCREMENT,
                nome  TEXT    NOT NULL,
                email TEXT    NOT NULL UNIQUE,
                senha TEXT    NOT NULL
            );
            CREATE TABLE IF NOT EXISTS consumo (
                id         INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id    INTEGER NOT NULL,
                bebida     TEXT    NOT NULL,
                quantidade REAL    NOT NULL,
                unidade    TEXT    NOT NULL,
                data       TEXT    NOT NULL,
                FOREIGN KEY (user_id) REFERENCES usuarios(id)
            );
            CREATE TABLE IF NOT EXISTS diario_emocional (
                id       INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id  INTEGER NOT NULL,
                humor    TEXT    NOT NULL,
                texto    TEXT    NOT NULL,
                data     TEXT    NOT NULL,
                FOREIGN KEY (user_id) REFERENCES usuarios(id)
            );
        """)
        self.conexao.commit()

    @staticmethod
    def _hash(senha):
        return hashlib.sha256(senha.encode()).hexdigest()

    def cadastrar(self, nome, email, senha):
        try:
            self.cursor.execute(
                "INSERT INTO usuarios (nome,email,senha) VALUES (?,?,?)",
                (nome.strip(), email.strip().lower(), self._hash(senha))
            )
            self.conexao.commit()
            return True
        except sqlite3.IntegrityError:
            return False

    def autenticar(self, email, senha):
        self.cursor.execute(
            "SELECT id,nome,email FROM usuarios WHERE email=? AND senha=?",
            (email.strip().lower(), self._hash(senha))
        )
        r = self.cursor.fetchone()
        return {"id": r[0], "nome": r[1], "email": r[2]} if r else None

    def registrar_consumo(self, uid, bebida, qtd, unidade):
        try:
            self.cursor.execute(
                "INSERT INTO consumo (user_id,bebida,quantidade,unidade,data)"
                " VALUES (?,?,?,?,?)",
                (uid, bebida, qtd, unidade,
                 datetime.datetime.now().strftime("%Y-%m-%d %H:%M"))
            )
            self.conexao.commit()
            return True
        except Exception as e:
            print(e); return False

    def historico(self, uid):
        self.cursor.execute(
            "SELECT bebida,quantidade,unidade,data FROM consumo"
            " WHERE user_id=? ORDER BY data DESC", (uid,)
        )
        return self.cursor.fetchall()

    def total(self, uid):
        self.cursor.execute(
            "SELECT COUNT(*) FROM consumo WHERE user_id=?", (uid,))
        return self.cursor.fetchone()[0]

    def dias_consecutivos(self, uid):
        self.cursor.execute(
            "SELECT DISTINCT DATE(data) FROM consumo"
            " WHERE user_id=? ORDER BY data DESC", (uid,))
        datas = [r[0] for r in self.cursor.fetchall()]
        if not datas: return 0
        streak = 1
        for i in range(1, len(datas)):
            d1 = datetime.date.fromisoformat(datas[i - 1])
            d2 = datetime.date.fromisoformat(datas[i])
            if (d1 - d2).days == 1: streak += 1
            else: break
        return streak

    def consumo_ultimos_dias(self, uid, dias=7):
        desde = (datetime.date.today() -
                 datetime.timedelta(days=dias)).isoformat()
        self.cursor.execute(
            "SELECT COUNT(*), SUM(quantidade) FROM consumo"
            " WHERE user_id=? AND DATE(data) >= ?", (uid, desde))
        r = self.cursor.fetchone()
        return r[0] or 0, r[1] or 0.0

    def salvar_diario(self, uid, humor, texto):
        self.cursor.execute(
            "INSERT INTO diario_emocional (user_id,humor,texto,data)"
            " VALUES (?,?,?,?)",
            (uid, humor, texto,
             datetime.datetime.now().strftime("%Y-%m-%d %H:%M")))
        self.conexao.commit()

    def listar_diario(self, uid, limite=10):
        self.cursor.execute(
            "SELECT humor,texto,data FROM diario_emocional"
            " WHERE user_id=? ORDER BY data DESC LIMIT ?", (uid, limite))
        return self.cursor.fetchall()

    def fechar(self):
        self.conexao.close()


