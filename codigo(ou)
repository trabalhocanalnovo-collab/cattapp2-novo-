                 font=F["body"], bg=C["bg_main"],
                 fg=C["text_muted"]).pack(anchor="w", pady=(8, 30))

        # Campos
        self._le = EntryModerno(form, "E-mail", largura=32)
        self._le.pack(fill="x", pady=(0, 12))
        self._ls = EntryModerno(form, "Senha", show="•", largura=32)
        self._ls.pack(fill="x", pady=(0, 32))

        self._le.bind_enter(lambda: self._ls.focus())
        self._ls.bind_enter(self._logar)

        # ── Botão principal (maior que v3) ───────────────────
        BotaoAnimado(
            form, "  Entrar na conta  →",
            self._logar, variante="login",
            fonte=F["btn_lg"], pady_base=17
        ).pack(fill="x", pady=(0, 18))

        # Divisor com texto
        div = tk.Frame(form, bg=C["bg_main"])
        div.pack(fill="x", pady=(0, 16))
        tk.Frame(div, bg=C["blue_mid"], height=1).pack(
            side="left", fill="x", expand=True, padx=(0, 10))
        tk.Label(div, text="ou", font=F["caption"],
                 bg=C["bg_main"], fg=C["text_dim"]).pack(side="left")
        tk.Frame(div, bg=C["blue_mid"], height=1).pack(
            side="left", fill="x", expand=True, padx=(10, 0))

        # Botão secundário (criar conta)
        BotaoAnimado(
            form, "  Criar nova conta",
            self._cadastro, variante="secundario",
            fonte=F["btn"], pady_base=14
        ).pack(fill="x")

        self._le.focus()

    # ── Lógica de login ──────────────────────────────────────
    def _logar(self):
        e = self._le.get().strip()
        s = self._ls.get().strip()
        if not e or not s:
            self.toast.mostrar("Preencha e-mail e senha.", "aviso"); return
        u = self.banco.autenticar(e, s)
        if u:
            self.ao_logar(u)
        else:
            self.toast.mostrar("E-mail ou senha incorretos.", "erro")

    # ── Tela de Cadastro ─────────────────────────────────────
    def _cadastro(self):
        self._limpar()
        cont = tk.Frame(self.frame, bg=C["bg_main"])
        cont.pack(fill="both", expand=True)
        self._painel_esq(cont)

        dir_ = tk.Frame(cont, bg=C["bg_main"])
        dir_.pack(side="left", fill="both", expand=True)

        # Scroll para caber todos os campos no cadastro
        sf = ScrollFrame(dir_, bg=C["bg_main"])
        sf.pack(fill="both", expand=True)
        form = tk.Frame(sf.interior, bg=C["bg_main"], padx=52, pady=24)
        form.pack(fill="x")
        sf.bind_scroll_em(form)

        tk.Label(form, text="Criar nova conta ✨",
                 font=F["h1"], bg=C["bg_main"],
                 fg=C["text_white"]).pack(anchor="w")
        tk.Label(form, text="Comece sua jornada de controle hoje",
                 font=F["body"], bg=C["bg_main"],
                 fg=C["text_muted"]).pack(anchor="w", pady=(6, 20))

        self._cn = EntryModerno(form, "Nome completo", largura=32)
        self._cn.pack(fill="x", pady=(0, 8))
        self._ce = EntryModerno(form, "E-mail", largura=32)
        self._ce.pack(fill="x", pady=(0, 8))
        self._cs = EntryModerno(form, "Senha (mín. 6 caracteres)",
                                show="•", largura=32)
        self._cs.pack(fill="x", pady=(0, 4))

        # Indicador de força de senha
        ind = IndicadorSenha(form, self._cs, bg=C["bg_main"])
        ind.pack(fill="x", pady=(0, 8))
        sf.bind_scroll_em(ind)

        self._cc = EntryModerno(form, "Confirmar senha",
                                show="•", largura=32)
        self._cc.pack(fill="x", pady=(0, 26))

        self._cc.bind_enter(self._fazer_cad)

        # Botão criar conta (grande)
        BotaoAnimado(
            form, "  Criar minha conta  →",
            self._fazer_cad, variante="sucesso",
            fonte=F["btn_lg"], pady_base=16
        ).pack(fill="x", pady=(0, 14))

        # Link voltar
        lf = tk.Frame(form, bg=C["bg_main"])
        lf.pack()
        tk.Label(lf, text="Já tenho conta.", font=F["body"],
                 bg=C["bg_main"], fg=C["text_muted"]).pack(side="left")
        lnk = tk.Label(lf, text=" Fazer login", font=F["btn"],
                       bg=C["bg_main"], fg=C["blue_light"], cursor="hand2")
        lnk.pack(side="left")
        lnk.bind("<Button-1>", lambda e: self._login())
        lnk.bind("<Enter>", lambda e: lnk.config(fg=C["text_white"]))
        lnk.bind("<Leave>", lambda e: lnk.config(fg=C["blue_light"]))

        self._cn.focus()
        sf.bind_scroll_em(form)

    # ── Lógica de cadastro ───────────────────────────────────
    def _fazer_cad(self):
        nome  = self._cn.get().strip()
        email = self._ce.get().strip()
        senha = self._cs.get().strip()
        conf  = self._cc.get().strip()
        if not all([nome, email, senha, conf]):
            self.toast.mostrar("Preencha todos os campos.", "aviso"); return
        if len(nome) < 2:
            self.toast.mostrar("Nome muito curto.", "aviso"); return
        if not re.match(r"[^@]+@[^@]+\.[^@]+", email):
            self.toast.mostrar("E-mail inválido.", "erro"); return
        if len(senha) < 6:
            self.toast.mostrar("Senha deve ter ao menos 6 caracteres.", "aviso"); return
        if senha != conf:
            self.toast.mostrar("As senhas não coincidem.", "erro"); return
        if self.banco.cadastrar(nome, email, senha):
            self.toast.mostrar(
                f"Conta criada! Bem-vindo(a), {nome.split()[0]}!", "sucesso")
            self._login()
        else:
            self.toast.mostrar("Este e-mail já está cadastrado.", "erro")


