#  WIDGET: EntryModerno — campo com borda de foco animada  ← MELHORADO v4.0
# =============================================================================
class EntryModerno(tk.Frame):
    """
    Campo de entrada com borda que anima suavemente ao receber foco.
    """
    def __init__(self, pai, rotulo, show="", largura=34, bg=None, **kw):
        bg = bg or C["bg_card"]
        super().__init__(pai, bg=bg, **kw)

        tk.Label(self, text=rotulo, font=F["body_sm"],
                 bg=bg, fg=C["text_muted"]).pack(anchor="w", pady=(10, 3))

        self._borda = tk.Frame(self, bg=C["blue_mid"], padx=1, pady=1)
        self._borda.pack(fill="x")

        self._entry = tk.Entry(
            self._borda, font=F["body_lg"],
            bg=C["bg_input"], fg=C["text_white"],
            insertbackground=C["blue_light"],
            relief="flat", bd=0, width=largura, show=show
        )
        self._entry.pack(fill="x", ipady=14, padx=1)

        # Animação de foco: interpola borda de blue_mid → blue_light
        self._entry.bind("<FocusIn>",  self._focus_in)
        self._entry.bind("<FocusOut>", self._focus_out)
        self._anim_id = None

    def _focus_in(self, event=None):
        """Anima a borda para a cor de destaque ao focar."""
        self._anim_borda(C["blue_mid"], C["blue_light"], passo=0)

    def _focus_out(self, event=None):
        """Anima a borda de volta ao estado normal ao desfocar."""
        self._anim_borda(C["blue_light"], C["blue_mid"], passo=0)

    def _anim_borda(self, c0, c1, passo):
        """Interpola a cor da borda do campo."""
        if self._anim_id:
            self.after_cancel(self._anim_id)
        if passo > ANIM_STEPS:
            self._borda.config(bg=c1); return
        t   = passo / ANIM_STEPS
        cor = hex_lerp(c0, c1, t)
        try:
            self._borda.config(bg=cor)
        except tk.TclError:
            return
        self._anim_id = self.after(
            ANIM_DELAY,
            lambda: self._anim_borda(c0, c1, passo + 1)
        )

    def get(self):         return self._entry.get()
    def limpar(self):      self._entry.delete(0, "end")
    def focus(self):       self._entry.focus_set()
    def bind_enter(self, fn): self._entry.bind("<Return>", lambda e: fn())
    def insert(self, txt):
