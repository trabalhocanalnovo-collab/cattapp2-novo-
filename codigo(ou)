# =============================================================================
class Toast:
    _CORES = {
        "sucesso": (C["green"],      C["green_dark"],  "✔  "),
        "erro":    (C["red"],        C["red_dark"],    "✖  "),
        "aviso":   (C["amber"],      C["amber_dark"],  "⚠  "),
        "info":    (C["blue_light"], C["bg_card"],     "ℹ  "),
    }

    def __init__(self, root):
        self.root   = root
        self._fila  = []
        self._ativo = False

    def mostrar(self, mensagem, tipo="info"):
        self._fila.append((mensagem, tipo))
        if not self._ativo:
            self._proximo()

    def _proximo(self):
        if not self._fila:
            self._ativo = False; return
        self._ativo = True
        self._exibir(*self._fila.pop(0))

    def _exibir(self, mensagem, tipo):
        cor_txt, cor_bg, icone = self._CORES.get(tipo, self._CORES["info"])
        popup = tk.Toplevel(self.root)
        popup.overrideredirect(True)
        popup.attributes("-topmost", True)
        popup.configure(bg=cor_bg)
        frame = tk.Frame(popup, bg=cor_bg, padx=18, pady=14)
        frame.pack()
        tk.Label(frame, text=icone, font=("Segoe UI", 14, "bold"),
                 bg=cor_bg, fg=cor_txt).pack(side="left")
        tk.Label(frame, text=mensagem, font=F["body_lg"],
                 bg=cor_bg, fg=C["text_white"],
                 wraplength=300, justify="left").pack(side="left")
        tk.Frame(popup, bg=cor_txt, height=3).pack(fill="x", side="bottom")
        self.root.update_idletasks()
        popup.update_idletasks()
        rx  = self.root.winfo_rootx()
        ry  = self.root.winfo_rooty()
        rw  = self.root.winfo_width()
        pw  = popup.winfo_width()
        popup.geometry(f"+{rx + rw - pw - 20}+{ry + 16}")
        popup.after(TOAST_DUR, lambda: (popup.destroy(), self._proximo()))


# =============================================================================
#  WIDGET: ScrollFrame  ← NOVO v4.0
#
#  Como funciona o scroll com mouse:
#  ─────────────────────────────────
#  1. Um tk.Canvas é criado como área de rolagem.
#  2. Um tk.Frame interno é inserido no canvas via create_window().
#  3. A função _bind_scroll() varre TODOS os widgets filhos (recursivo)
#     e registra dois eventos:
#       • <MouseWheel>  → Windows e macOS usam este evento.
#                         event.delta vem em múltiplos de 120 (Win) ou
#                         1 (Mac), então dividimos por 120 no Windows.
#       • <Button-4> e <Button-5> → Linux usa botões 4/5 para rolar.
#  4. O handler chama canvas.yview_scroll(n, "units"), onde n=1 rola
#     para baixo e n=-1 para cima.
#  5. _bind_scroll() é chamado novamente sempre que um novo widget
#     é adicionado ao frame, via trace no StringVar do Canvas.
# =============================================================================
class ScrollFrame(tk.Frame):
    """
    Frame com scroll vertical ativado pelo mouse.
    Uso: sf = ScrollFrame(pai)  →  adicione widgets em sf.interior
    """

    def __init__(self, pai, bg=None, **kw):
        bg = bg or C["bg_main"]
        super().__init__(pai, bg=bg, **kw)

        # Canvas é o widget visível que "janela" o conteúdo interno
        self._canvas = tk.Canvas(self, bg=bg, highlightthickness=0,
                                 bd=0)

        # Scrollbar vertical (opcional: pode ser ocultada)
        self._vsb = ttk.Scrollbar(self, orient="vertical",
                                  command=self._canvas.yview)
        self._canvas.configure(yscrollcommand=self._vsb.set)

        self._vsb.pack(side="right", fill="y")
        self._canvas.pack(side="left", fill="both", expand=True)

        # Frame interno onde os widgets reais são colocados
        self.interior = tk.Frame(self._canvas, bg=bg)
        self._win_id  = self._canvas.create_window(
            (0, 0), window=self.interior, anchor="nw")

        # Ajustar largura do frame interno ao canvas
        self._canvas.bind("<Configure>", self._on_canvas_resize)

        # Atualizar scrollregion quando o interior mudar de tamanho
        self.interior.bind("<Configure>", self._on_interior_resize)

        # ── Binding de scroll do mouse ────────────────────────
        # Chamamos _bind_scroll no interior e em si mesmo para
        # garantir que qualquer filho captura o evento e repassa.
        self._bind_scroll(self)
        self._bind_scroll(self._canvas)
        self._bind_scroll(self.interior)

    # ── Resize handlers ──────────────────────────────────────
    def _on_canvas_resize(self, event):
        """Mantém o frame interno com a mesma largura do canvas."""
        self._canvas.itemconfig(self._win_id, width=event.width)

    def _on_interior_resize(self, event):
        """Atualiza a scrollregion para abranger todo o conteúdo."""
        self._canvas.configure(
            scrollregion=self._canvas.bbox("all"))

    # ── Scroll handler ────────────────────────────────────────
    def _scroll_handler(self, event):
        """
        Interpreta o evento de scroll do mouse e rola o canvas.

        Windows/macOS: event.delta é +120 (cima) ou -120 (baixo)
        Linux:         Button-4 = cima, Button-5 = baixo
        """
        # Detectar plataforma
        if event.num == 4:          # Linux: scroll up
            self._canvas.yview_scroll(-1, "units")
        elif event.num == 5:        # Linux: scroll down
            self._canvas.yview_scroll(1, "units")
        else:
            # Windows dá delta em múltiplos de 120
            # macOS dá valores menores, dividimos também
            delta = -1 if event.delta > 0 else 1
            self._canvas.yview_scroll(delta, "units")

    def _bind_scroll(self, widget):
        """
        Registra o scroll handler neste widget e em todos os filhos
        recursivamente.  Precisa ser chamado depois que os filhos
        forem criados para garantir cobertura total.
        """
        # Windows / macOS
        widget.bind("<MouseWheel>", self._scroll_handler, add="+")
        # Linux
        widget.bind("<Button-4>",   self._scroll_handler, add="+")
        widget.bind("<Button-5>",   self._scroll_handler, add="+")

        for child in widget.winfo_children():
            self._bind_scroll(child)

    def bind_scroll_em(self, widget):
        """
        Método público: registra scroll em qualquer widget adicionado
        DEPOIS da construção do ScrollFrame.
        Chame após adicionar widgets ao self.interior.
        """
        self._bind_scroll(widget)

    def scroll_topo(self):
        """Rola de volta ao início (útil ao trocar de tela)."""
        self._canvas.yview_moveto(0)


# =============================================================================
#  WIDGET: BotaoAnimado  ← MELHORADO v4.0
#
#  Como funcionam os efeitos de botão:
#  ─────────────────────────────────────
#  1. HOVER SUAVE (transição de cor):
#     Ao passar o mouse (<Enter>), inicia uma animação com after().
#     A função _animar_hover() é chamada N vezes com delay de
#     ANIM_DELAY ms. A cada chamada ela calcula a cor interpolada
#     usando hex_lerp(cor_normal, cor_hover, passo/total) e aplica
#     com config(bg=...). Isso cria uma transição suave em vez de
#     pular abruptamente de uma cor para outra.
#
#  2. CLIQUE (efeito press/release):
#     Em <ButtonPress-1>: encurta o pady em 2px para simular
#     "afundamento" e escurece levemente o fundo.
#     Em <ButtonRelease-1>: restaura o pady e dispara o comando.
#     O efeito é sutil mas perceptível e melhora o feedback tátil.
#
#  3. CURSOR:
#     cursor="hand2" sempre presente — mostra a mãozinha ao hover.
# =============================================================================
class BotaoAnimado(tk.Label):
    """
    Botão com transição suave de cor no hover e efeito de clique.
    Substitui o BotaoModerno da v3 com animações mais polidas.
    """

    _VAR = {
        "primario":   ("#1255B8",        "#1E90FF",        C["text_white"]),
        "secundario": ("#1E293B",        "#2E4260",        C["text_white"]),
        "perigo":     (C["red_dark"],    C["red"],         C["text_white"]),
        "sucesso":    (C["green_dark"],  C["green"],       "#082010"),
        "ghost":      (C["bg_main"],     "#1E293B",        C["blue_soft"]),
        "purple":     (C["purple_dark"], C["purple"],      C["text_white"]),
        "teal":       (C["teal_dark"],   C["teal"],        C["text_white"]),
        "amber":      (C["amber_dark"],  C["amber"],       "#1a0a00"),
        "login":      ("#1255B8",        "#1E90FF",        C["text_white"]),
    }

    def __init__(self, pai, texto, comando, variante="primario",
                 largura=0, fonte=None, pady_base=14, **kw):
        self._cn, self._ch, self._ct = self._VAR.get(
            variante, self._VAR["primario"])
        self._cmd       = comando
        self._hovered   = False
        self._anim_id   = None    # ID do after() em andamento
        self._pady_base = pady_base

        fonte = fonte or F["btn_lg"]
        super().__init__(
            pai, text=texto, font=fonte,
            bg=self._cn, fg=self._ct,
            cursor="hand2", relief="flat",
            padx=28, pady=pady_base, **kw
        )
        if largura:
            self.config(width=largura)

        # ── Eventos ──────────────────────────────────────────
        self.bind("<Enter>",           self._on_enter)
        self.bind("<Leave>",           self._on_leave)
        self.bind("<ButtonPress-1>",   self._on_press)
        self.bind("<ButtonRelease-1>", self._on_release)

    # ── Hover: início (mouse entra) ──────────────────────────
    def _on_enter(self, event=None):
        """Inicia a animação de transição para a cor hover."""
        self._hovered = True
        self._cancelar_anim()
        self._animar(self._cn, self._ch, passo=0, direcao=1)

    # ── Hover: fim (mouse sai) ───────────────────────────────
    def _on_leave(self, event=None):
        """Inicia a animação de volta para a cor normal."""
        self._hovered = False
        self._cancelar_anim()
        cor_atual = self.cget("bg")
        self._animar(cor_atual, self._cn, passo=0, direcao=1)

    def _cancelar_anim(self):
        """Cancela animação anterior para evitar conflitos."""
        if self._anim_id:
            self.after_cancel(self._anim_id)
            self._anim_id = None

    def _animar(self, c_inicio, c_fim, passo, direcao):
        """
        Interpola a cor do botão de c_inicio até c_fim em
        ANIM_STEPS passos, com ANIM_DELAY ms entre cada frame.
        """
        if passo > ANIM_STEPS:
            self.config(bg=c_fim)
            return
        t   = passo / ANIM_STEPS
        cor = hex_lerp(c_inicio, c_fim, t)
        try:
            self.config(bg=cor)
        except tk.TclError:
            return   # widget pode ter sido destruído
        self._anim_id = self.after(
            ANIM_DELAY,
            lambda: self._animar(c_inicio, c_fim, passo + 1, direcao)
        )

    # ── Clique: press (afunda) ───────────────────────────────
    def _on_press(self, event=None):
        """
        Simula afundamento: reduz o pady em 2px e escurece levemente
        interpolando 30% para o estado inicial.
        """
        self._cancelar_anim()
        escuro = hex_lerp(self._ch, self._cn, 0.35)
        self.config(bg=escuro, pady=max(self._pady_base - 2, 4))

    # ── Clique: release (sobe e executa) ─────────────────────
    def _on_release(self, event=None):
        """Restaura aparência e executa o comando."""
        self.config(pady=self._pady_base)
        # Volta para hover pois o mouse ainda está sobre o botão
        self._animar(self._cn, self._ch, passo=0, direcao=1)
        if self._cmd:
            self._cmd()


