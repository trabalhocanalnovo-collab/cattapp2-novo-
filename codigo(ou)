# =============================================================================
#  UTILITÁRIOS DE COR  (para animação de hover)
# =============================================================================

def hex_para_rgb(hex_cor: str) -> tuple:
    """
    Converte '#RRGGBB' → (R, G, B) inteiros 0-255.
    Usado pela interpolação de cores dos botões.
    """
    h = hex_cor.lstrip("#")
    return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))

def rgb_para_hex(r: int, g: int, b: int) -> str:
    """(R, G, B) → '#RRGGBB'"""
    return f"#{int(r):02x}{int(g):02x}{int(b):02x}"

def hex_lerp(c_inicio: str, c_fim: str, t: float) -> str:
    """
    Interpola linearmente entre duas cores hex.
    t=0 → c_inicio  |  t=1 → c_fim
    Usado para criar transição suave de cor nos botões.
    """
    r0, g0, b0 = hex_para_rgb(c_inicio)
    r1, g1, b1 = hex_para_rgb(c_fim)
    return rgb_para_hex(
        r0 + (r1 - r0) * t,
        g0 + (g1 - g0) * t,
        b0 + (b1 - b0) * t,
    )


