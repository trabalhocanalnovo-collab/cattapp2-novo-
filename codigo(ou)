        do.pack(fill="x", padx=24, pady=(0, 16))
        tk.Label(di, text="Como você está se sentindo agora?",
                 font=F["h3"], bg=C["bg_card"],
                 fg=C["text_white"]).pack(anchor="w", pady=(0, 10))

        hf = tk.Frame(di, bg=C["bg_card"])
        hf.pack(fill="x", pady=(0, 16))
        self._humor_btns = {}
        for emoji, label, cor in self.HUMORES:
            w = tk.Label(hf, text=f"{emoji}\n{label}",
                font=F["caption"], bg=C["bg_input"],
                fg=C["text_muted"], cursor="hand2",
                padx=9, pady=9, justify="center")
            w.pack(side="left", padx=4)
            self._humor_btns[(emoji, label)] = w
            w.bind("<Button-1>",
                   lambda e, em=emoji, lb=label, c=cor:
                   self._sel_humor(em, lb, c))
            sf_widget.bind_scroll_em(w)

        tk.Label(di, text="Descreva o que está sentindo ou pensando:",
                 font=F["body_sm"], bg=C["bg_card"],
                 fg=C["text_muted"]).pack(anchor="w", pady=(0, 6))
        self._txt_diario = tk.Text(di, font=F["body_lg"],
            bg=C["bg_input"], fg=C["text_white"],
            insertbackground=C["blue_light"],
            relief="flat", bd=0, height=5, wrap="word", padx=10, pady=10)
        self._txt_diario.pack(fill="x")

        bf = tk.Frame(di, bg=C["bg_card"])
        bf.pack(fill="x", pady=(14, 0))
        BotaoAnimado(bf, "💾  Salvar no Diário", self._salvar_diario,
                     variante="amber", fonte=F["btn"], pady_base=12).pack(side="left")

        # Histórico do diário
        entradas = self.banco.listar_diario(self.usuario["id"], limite=5)
        if entradas:
            eo, ei = criar_card(sf, "Últimas Entradas do Diário",
                                icone="📚", pad_x=24, pad_y=16)
            eo.pack(fill="x", padx=24, pady=(0, 16))
            for humor, texto, data in entradas:
                try:
                    dt = datetime.datetime.strptime(data, "%Y-%m-%d %H:%M")
                    df = dt.strftime("%d/%m/%Y  %H:%M")
                except Exception:
                    df = data
                ef = tk.Frame(ei, bg=C["bg_input"], padx=12, pady=10)
                ef.pack(fill="x", pady=4)
                tk.Label(ef, text=f"{humor}  •  {df}",
                         font=F["body_sm"], bg=C["bg_input"],
                         fg=C["text_muted"]).pack(anchor="w")
                tk.Label(ef, text=texto[:160] + ("..." if len(texto) > 160 else ""),
                         font=F["body"], bg=C["bg_input"],
                         fg=C["text_white"], anchor="w",
                         justify="left", wraplength=640).pack(anchor="w")
                sf_widget.bind_scroll_em(ef)

        frases_psi = [
            "\"Pedir ajuda é um sinal de coragem, não de fraqueza.\"",
            "\"Seus sentimentos são válidos. E você merece apoio.\"",
            "\"A recuperação não é uma linha reta — é uma jornada.\"",
            "\"Você não precisa estar bem o tempo todo.\"",
        ]
        fo, fi = criar_card(sf, pad_x=24, pad_y=16)
        fo.pack(fill="x", padx=24, pady=(0, 24))
        tk.Label(fi, text="💜  " + random.choice(frases_psi),
                 font=("Segoe UI", 11, "italic"),
                 bg=C["bg_card"], fg=C["purple"],
                 wraplength=680, justify="left").pack(anchor="w")

        sf_widget.bind_scroll_em(sf)

    def _sel_humor(self, emoji, label, cor):
        for (em, lb), w in self._humor_btns.items():
            w.config(bg=C["bg_input"], fg=C["text_muted"])
        self._humor_sel.set(f"{emoji} {label}")
        self._humor_btns[(emoji, label)].config(bg=C["bg_card"], fg=cor)

    def _salvar_diario(self):
        humor = self._humor_sel.get()
        texto = self._txt_diario.get("1.0", "end").strip()
        if not humor:
            self.toast.mostrar("Selecione como você está se sentindo.", "aviso"); return
        if len(texto) < 5:
            self.toast.mostrar("Escreva pelo menos uma frase.", "aviso"); return
        self.banco.salvar_diario(self.usuario["id"], humor, texto)
        self.toast.mostrar("Entrada salva no diário! 📝", "sucesso")
        self._build()

    def _toggle_respiracao(self):
        if self._respirando:
            self._respirando = False
            self._btn_resp.config(text="▶  Iniciar Respiração Guiada")
            self._lbl_resp.config(text="Pausado.")
            self._lbl_count.config(text="")
        else:
            self._respirando = True
            self._ciclo = 0
            self._fase_resp = 0
            self._tick = 4
            self._btn_resp.config(text="⏹  Parar")
            self._animar_resp()

    def _animar_resp(self):
        if not self._respirando: return
        FASES = [
            ("🌬️  INSPIRE...", 4, C["teal"]),
            ("🤚  SEGURE...",   7, C["amber"]),
            ("💨  EXPIRE...",   8, C["purple"]),
        ]
        fase_idx = self._fase_resp % 3
        label, duracao, cor = FASES[fase_idx]
        tick = getattr(self, "_tick", duracao)
        if tick > 0:
            self._lbl_resp.config(text=label, fg=cor)
            self._lbl_count.config(text=str(tick), fg=cor)
            self._tick = tick - 1
            self.frame.after(1000, self._animar_resp)
        else:
            self._fase_resp += 1
            self._tick = FASES[self._fase_resp % 3][1]
            if self._fase_resp % 3 == 0:
                self._ciclo += 1
                if self._ciclo >= 4:
                    self._respirando = False
                    self._btn_resp.config(text="▶  Iniciar Respiração Guiada")
                    self._lbl_resp.config(text="✅  4 ciclos concluídos! Muito bem!", fg=C["green"])
                    self._lbl_count.config(text="")
                    self.toast.mostrar("Exercício de respiração concluído! 🌟", "sucesso")
                    return
            self._animar_resp()


# =============================================================================
#  CLASSE PRINCIPAL: App
# =============================================================================
class App:
    LARGURA = 1100
    ALTURA  = 720
    TITULO  = f"{APP_NOME} — Centro de Apoio e Transformação"

    def __init__(self):
        self.root = tk.Tk()
        self.root.title(self.TITULO)
        self.root.configure(bg=C["bg_main"])
        self.root.resizable(True, True)
        self.root.minsize(860, 600)

        self.root.update_idletasks()
        sw = self.root.winfo_screenwidth()
        sh = self.root.winfo_screenheight()
        x  = (sw - self.LARGURA) // 2
        y  = (sh - self.ALTURA)  // 2
        self.root.geometry(f"{self.LARGURA}x{self.ALTURA}+{x}+{y}")

        self.banco   = BancoDados()
        self.usuario = None
        self.toast   = Toast(self.root)

        self._raiz = tk.Frame(self.root, bg=C["bg_main"])
        self._raiz.pack(fill="both", expand=True)
        self._sidebar  = None
        self._conteudo = None

        self._ir_login()
        self.root.protocol("WM_DELETE_WINDOW", self._fechar)

    def _ir_login(self):
        for w in self._raiz.winfo_children():
            w.destroy()
        self._sidebar  = None
        self._conteudo = tk.Frame(self._raiz, bg=C["bg_main"])
        self._conteudo.pack(fill="both", expand=True)
        TelaLogin(self._conteudo, self.banco, self.toast, self._ao_logar)

    def _montar_app(self):
        for w in self._raiz.winfo_children():
            w.destroy()
        self._sidebar = Sidebar(self._raiz, self.usuario,
                                ao_navegar=self._navegar, ao_sair=self._sair)
        self._sidebar.pack(side="left", fill="y")
        tk.Frame(self._raiz, bg=C["blue_light"], width=1).pack(
            side="left", fill="y")
        self._conteudo = tk.Frame(self._raiz, bg=C["bg_main"])
        self._conteudo.pack(side="left", fill="both", expand=True)

    def _navegar(self, tela):
        for w in self._conteudo.winfo_children():
            w.destroy()
        if self._sidebar:
            self._sidebar.definir_ativo(tela)
        if tela == "dashboard":
            TelaDashboard(self._conteudo, self.banco,
                          self.usuario, self.toast, self._navegar)
        elif tela == "consumo":
            TelaConsumo(self._conteudo, self.banco,
                        self.usuario, self.toast,
                        ao_voltar=lambda: self._navegar("dashboard"))
        elif tela == "historico":
            TelaHistorico(self._conteudo, self.banco,
                          self.usuario, self.toast,
                          ao_voltar=lambda: self._navegar("dashboard"))
        elif tela == "medico":
            TelaMedico(self._conteudo, self.banco,
                       self.usuario, self.toast,
                       ao_voltar=lambda: self._navegar("dashboard"))
        elif tela == "psicologico":
            TelaPsicologico(self._conteudo, self.banco,
                            self.usuario, self.toast,
                            ao_voltar=lambda: self._navegar("dashboard"))

    def _ao_logar(self, u):
        self.usuario = u
        self._montar_app()
        self._navegar("dashboard")
        self.toast.mostrar(
            f"Login realizado! Olá, {u['nome'].split()[0]}. 👋", "sucesso")

    def _sair(self):
        self.usuario = None
        self._ir_login()

    def _fechar(self):
        self.banco.fechar()
        self.root.destroy()

    def iniciar(self):
        self.root.mainloop()


# =============================================================================
#  PONTO DE ENTRADA
# =============================================================================
if __name__ == "__main__":
    app = App()
    app.iniciar()
