# =============================================================================
#  WIDGET: IndicadorSenha  ← NOVO v4.0
#  Barra visual que mede a força da senha em tempo real
# =============================================================================
class IndicadorSenha(tk.Frame):
    """
    Mostra uma barra colorida indicando a força da senha:
    Muito fraca (vermelho) → Fraca → Média → Forte → Muito forte (verde)
    """
    NIVEIS = [
        (C["red"],        "Muito fraca"),
        (C["red"],        "Fraca"),
        (C["amber"],      "Média"),
        (C["blue_light"], "Forte"),
        (C["green"],      "Muito forte"),
    ]

    def __init__(self, pai, entry_widget, bg=None, **kw):
        bg = bg or C["bg_card"]
        super().__init__(pai, bg=bg, **kw)
        self._entry = entry_widget

        self._barra_bg = tk.Frame(self, bg=C["bg_input"], height=4)
        self._barra_bg.pack(fill="x")
        self._barra_fill = tk.Frame(self._barra_bg, bg=C["red"], height=4)
        self._barra_fill.place(relwidth=0, relheight=1)

        self._lbl = tk.Label(self, text="", font=F["caption"],
                             bg=bg, fg=C["text_dim"])
        self._lbl.pack(anchor="e", pady=(2, 0))

        # Conecta ao Entry para atualizar em tempo real
        self._entry._entry.bind("<KeyRelease>", self._atualizar)

    def _pontuacao(self, senha):
        """
        Calcula 0-4 baseado em:
        tamanho, maiúsculas, números, símbolos, comprimento total
        """
        pts = 0
        if len(senha) >= 6:  pts += 1
        if len(senha) >= 10: pts += 1
        if re.search(r"[A-Z]", senha): pts += 1
        if re.search(r"\d", senha):    pts += 1
        if re.search(r"[^A-Za-z0-9]", senha): pts += 1
        return min(pts, 4)

    def _atualizar(self, event=None):
        senha = self._entry.get()
        if not senha:
            self._barra_fill.place(relwidth=0, relheight=1)
            self._lbl.config(text="")
            return
        pts  = self._pontuacao(senha)
        cor, texto = self.NIVEIS[pts]
        self._barra_fill.place(relwidth=(pts + 1) / 5, relheight=1)
        self._barra_fill.config(bg=cor)
        self._lbl.config(text=texto, fg=cor)


